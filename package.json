{
  "name": "access-lens",
  "private": true,
  "version": "0.0.0",
  "description": "Access observability SDK for modern SaaS apps",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter \"@access-lens/core\" test",
    "dev:demo": "pnpm --filter @access-lens/demo-react dev",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "clean": "pnpm -r exec rm -rf dist node_modules .turbo"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.6.3",
    "vitepress": "^1.6.4"
  },
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=20"
  }
}

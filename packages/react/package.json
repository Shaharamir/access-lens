{
  "name": "@access-lens/react",
  "version": "0.1.0",
  "description": "React adapter for Access Lens — typed Provider, AccessGate, and hooks bound to your defineAccessLens config.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "react",
    "access-control",
    "rbac",
    "permissions",
    "feature-flags",
    "entitlements",
    "observability",
    "saas",
    "authorization",
    "typescript",
    "headless"
  ],
  "author": "Shahar Amir <shahramir3@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/shahar-amir/access-lens#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shahar-amir/access-lens.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/shahar-amir/access-lens/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "@access-lens/core": "workspace:^"
  },
  "dependencies": {
    "@access-lens/core": "workspace:^"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "typescript": "^5.6.3"
  }
}
